# Codex Web — environment variables.
#
# Copy this file to `.env` and edit to match your environment, or export
# these in your shell / Replit secrets panel.

# Path to the `codex` (multitool) or `codex-app-server` (standalone) binary.
# - Multitool: the gateway invokes `$CODEX_BIN app-server` and dispatches on
#   the subcommand.
# - Standalone `codex-app-server`: the gateway invokes the binary directly.
# This web app now requires a real backend in every environment.
CODEX_BIN=/home/runner/codex-bin/codex

# Port the HTTP + WS server binds on. Replit maps 5000 → the public URL.
PORT=5000

# Enables production cookie flags and disables cache-busting `Cache-Control: no-store`.
NODE_ENV=production

# Root directory for per-session workspaces. Each session gets a unique
# subdirectory under this path. Defaults to `web/.workdirs` inside the repo.
CODEX_WEB_WORKDIR_ROOT=/tmp/codex-web-workdirs

# Public client ID used when refreshing ChatGPT OAuth tokens. If unset,
# the gateway falls back to the same public client ID baked into the CLI.
CODEX_CHATGPT_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
