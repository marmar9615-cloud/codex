# syntax=docker/dockerfile:1.7

FROM rust:1.93.0-bookworm AS backend-builder

ENV CARGO_BUILD_JOBS=1
ENV CARGO_PROFILE_RELEASE_CODEGEN_UNITS=16
ENV CARGO_PROFILE_RELEASE_LTO=off
ENV RUSTFLAGS="-C debuginfo=0"

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates pkg-config libcap-dev libssl-dev \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY codex-rs ./codex-rs

WORKDIR /app/codex-rs
RUN --mount=type=cache,target=/usr/local/cargo/registry,sharing=locked \
  --mount=type=cache,target=/usr/local/cargo/git,sharing=locked \
  --mount=type=cache,target=/app/codex-rs/target,sharing=locked \
  cargo build --locked --release --jobs 1 -p codex-app-server --bin codex-app-server --ignore-rust-version

FROM node:22-bookworm-slim AS web-deps

WORKDIR /app/web
COPY web/package.json web/package-lock.json ./
RUN npm ci --omit=dev

FROM node:22-bookworm-slim

ENV NODE_ENV=production
ENV CODEX_BIN=/usr/local/bin/codex-app-server

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash ca-certificates git python3 ripgrep \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app/web

COPY --from=backend-builder /app/codex-rs/target/release/codex-app-server /usr/local/bin/codex-app-server
COPY --from=web-deps /app/web/node_modules ./node_modules
COPY web ./

EXPOSE 5000

CMD ["node", "server.mjs"]
